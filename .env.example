# Server
PORT=3000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=qistonpe

# JWT Secrets
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# Email (Mailtrap Sandbox)
COMMON_EMAIL_SHOULD_QUEUE=true
COMMON_SMTP_EMAIL_SMTP_HOST=sandbox.smtp.mailtrap.io
COMMON_SMTP_EMAIL_SMTP_PORT=587
COMMON_SMTP_EMAIL_USERNAME=your_mailtrap_username
COMMON_SMTP_EMAIL_PASSWORD=your_mailtrap_password
COMMON_EMAIL_FROM=no-reply@qistonpe.com

# RabbitMQ
RABBITMQ_URL=amqp://localhost

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
